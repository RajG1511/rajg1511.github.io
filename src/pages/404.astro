---
// 404: small, in-voice, points somewhere useful.
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — no reading at this coordinate" description="Page not found.">
  <div class="wrap">
    <p class="annotation">Error 404 · signal lost</p>
    <h1>No reading at this coordinate.</h1>
    <p>
      The page you asked for isn't in the log. Try the <a href="/">home page</a>, the
      <a href="/work/">work log</a>, or the <a href="/blog/">blog</a>.
    </p>
  </div>
</BaseLayout>

<style>
  .wrap {
    padding-block: clamp(3rem, 10vw, 6rem);
  }
  .wrap .annotation {
    margin-bottom: 0.8rem;
  }
</style>
